# GitHub OAuth Client Credentials
# Create a GitHub OAuth App or GitHub App on github.com
# For local dev: Homepage URL = http://localhost:5173, Authorization Callback URL = http://localhost:5173
VITE_GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Optional: Personal Access Token to avoid public rate-limiting
GITHUB_TOKEN=your_personal_access_token_here
